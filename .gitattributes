# Auto-detect line endings — checkout as-is, store as LF in repo
* text=auto

# Python source files: LF in repo, checkout native
*.py            text diff=python
*.pyw           text
*.pyx           text
*.pxd           text
*.pxi           text

# Shell scripts: LF in repo, checkout LF on all platforms
*.sh            text eol=lf

# Batch/PowerShell: CRLF in repo, checkout native
*.bat           text eol=crlf
*.ps1           text eol=crlf
*.cmd           text eol=crlf

# Markdown/text: LF in repo, checkout native
*.md            text diff=markdown
*.rst           text
*.txt           text

# Config files: LF in repo, checkout native
*.cfg           text
*.ini           text
*.conf          text
*.json          text
*.yaml          text
*.yml           text
*.toml          text
Dockerfile      text
Makefile        text

# Git files
.gitignore      text
.gitattributes  text

# Binaries — detect as binary, never modify
*.db            binary
*.png           binary
*.jpg           binary
*.ico           binary
*.gif           binary
*.pdf           binary
*.pkl           binary
*.exe           binary
*.dll           binary
*.so            binary
